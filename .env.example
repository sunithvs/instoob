# YouTube OAuth credentials (from setup_youtube.py)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Instagram auth (pick ONE method):
# Option 1: Username + password (simplest, no 2FA)
IG_PASSWORD=

# Option 2: Session cookie (for 2FA accounts)
# Generate: base64 -i ~/.config/instaloader/session-YOUR_USERNAME
IG_SESSION_BASE64=
